# Environment variables required by this Hermes profile distribution.
# Copy to .env locally and fill values. Do not commit real .env.

# Local 9router connection key.
# required
9ROUTER_API_KEY=

# Dashboard web interface credentials.
# required
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
DASHBOARD_SECRET=
# Context7 MCP authorization token.
# required
CONTEXT7_API_KEY=

# Hindsight memory API key for production memory (if using cloud/external embeddings).
# optional
HINDSIGHT_LLM_API_KEY=

# Discord gateway bot token for public-agent.
# optional
DISCORD_BOT_TOKEN=

# Trusted human Discord user allowlist.
# optional
DISCORD_ALLOWED_USERS=

# Discord room boundaries and channel restrictions
DISCORD_ALLOWED_CHANNELS=*
DISCORD_FREE_RESPONSE_CHANNELS=
DISCORD_IGNORED_CHANNELS=
DISCORD_THREAD_REQUIRE_MENTION=true
DISCORD_NO_THREAD_CHANNELS=*
DISCORD_REQUIRE_MENTION=true
DISCORD_AUTO_THREAD=false
DISCORD_IGNORE_NO_MENTION=true
DISCORD_ALLOW_MENTION_REPLIED_USER=false
HERMES_DISCORD_BOT_TEXT_BATCH_DELAY_SECONDS=2.5
DISCORD_HOME_CHANNEL=
DISCORD_HOME_CHANNEL_THREAD_ID=

# Bot-message acceptance policy; use 'mentions' for controlled bot-to-bot relay.
# optional
# default: mentions
DISCORD_ALLOW_BOTS=

# Repeat raw mention on split Discord chunks for deterministic relay.
# optional
# default: true
DISCORD_REPEAT_MENTIONS_ON_SPLIT=
# Groq Whisper STT key for Indonesian voice transcription.
# optional
GROQ_API_KEY=

# Obsidian vault path for public-agent-readable continuity notes.
# optional
OBSIDIAN_VAULT_PATH=

# CS local browser and Camoufox proxy URL (e.g. http://camoufox-browser:9377)
CAMOFOX_URL=http://camoufox-browser:9377

# Telegram gateway bot token.
# optional
TELEGRAM_BOT_TOKEN=

# Email integration address.
# optional
EMAIL_ADDRESS=

# Email integration app password.
# optional
EMAIL_PASSWORD=

# Linear & Github auth token
LINEAR_MCP_ACCESS_TOKEN=
GITHUB_TOKEN=

# Linear MCP OAuth/auth state; configured interactively, not stored in distribution.
# optional
LINEAR_MCP_AUTH=

# Notion MCP OAuth/auth state; configured interactively and by sharing Notion pages/databases with the connection.
# optional
NOTION_MCP_AUTH=

# ntfy topic for public-agent push notifications; optional if config.yaml extra.topic is set. Use a private/random topic and do not publish it.
# optional
NTFY_TOPIC=

# Optional ntfy bearer/basic token for protected/self-hosted ntfy topics.
# optional
NTFY_TOKEN=

# Web Search & Data Scraping API keys.
# optional
EXA_API_KEY=
FIRECRAWL_API_KEY=

# 9router stream cookie auth token.
# optional
9ROUTER_MCP_AUTH_TOKEN=

# Hindsight local vector configuration & timeouts
HINDSIGHT_TIMEOUT=120
HINDSIGHT_IDLE_TIMEOUT=300

# Hindsight memory plugin worker settings
HINDSIGHT_API_WORKER_ENABLED=false
HINDSIGHT_API_WORKER_MAX_SLOTS=2
HINDSIGHT_API_WORKER_CONSOLIDATION_MAX_SLOTS=1
HINDSIGHT_API_WORKER_RETAIN_MAX_SLOTS=1
HINDSIGHT_API_WORKER_FILE_CONVERT_RETAIN_MAX_SLOTS=0
HINDSIGHT_API_WORKER_POLL_INTERVAL_MS=2000
HINDSIGHT_API_LLM_MAX_CONCURRENT=2
HINDSIGHT_API_DB_POOL_MAX_SIZE=10

# Image model configuration
OPENAI_COMPATIBLE_IMAGE_BASE_URL=http://9router:20128/v1
OPENAI_COMPATIBLE_IMAGE_MODEL=cx/gpt-5.5

# API Server settings
API_SERVER_ENABLED=true
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=8642
API_SERVER_KEY=

# Email IMAP/SMTP details
EMAIL_HOME_ADDRESS=
EMAIL_HOME_ADDRESS_NAME=
EMAIL_POLL_INTERVAL=90
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_ALLOWED_USERS=

# Whatsapp Gateway integration details
WHATSAPP_MODE=self-chat
WHATSAPP_ENABLED=true
WHATSAPP_ALLOWED_USERS=

# Modal executor credentials
SUDO_PASSWORD=
TERMINAL_ENV=docker
OPENROUTER_API_KEY=
TINKER_API_KEY=
WANDB_API_KEY=
TELEGRAM_ALLOWED_USERS=
TELEGRAM_HOME_CHANNEL=
# Bitwarden Secrets Manager machine-account access token for public-agent; required only after secrets.bitwarden.enabled is true.
# optional
PUBLIC_BWS_ACCESS_TOKEN=
