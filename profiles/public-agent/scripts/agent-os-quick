#!/usr/bin/env bash
set -euo pipefail
HERMES_HOME="${HERMES_HOME:-/home/galyarder/.hermes}"
REPO="$HERMES_HOME/hermes-agent"
SCRIPTS="$HERMES_HOME/scripts"
cmd="${1:-help}"
shift || true
cd "$REPO"
case "$cmd" in
  doctor-all)
    echo '== hermes version =='; hermes --version
    echo '== config checks =='; hermes config check || true; hermes --profile galyarder config check || true
    echo '== memory =='; hermes memory status; hermes --profile galyarder memory status; hermes --profile honcho-sandbox memory status || true
    echo '== profiles =='; hermes profile list
    ;;
  profile-audit)
    python "$SCRIPTS/profile-audit.py" "$@"
    ;;
  skill-sync-check)
    hermes skills list >/tmp/agent-os-skills-default.txt
    hermes --profile galyarder skills list >/tmp/agent-os-skills-galyarder.txt
    wc -l /tmp/agent-os-skills-default.txt /tmp/agent-os-skills-galyarder.txt
    echo 'wrote /tmp/agent-os-skills-default.txt and /tmp/agent-os-skills-galyarder.txt'
    ;;
  relay-smoke-test)
    python "$SCRIPTS/relay-smoke-test.py" "$@"
    ;;
  mcp-test)
    echo '== default mcp =='; hermes mcp list
    echo '== galyarder mcp =='; hermes --profile galyarder mcp list
    ;;
  voice-smoke)
    python "$SCRIPTS/voice-smoke.py" "$@"
    ;;
  agent-os-health)
    python "$SCRIPTS/agent-os-health-audit.py" "$@"
    ;;
  behavioral-regression)
    python "$SCRIPTS/agent-os-behavioral-regression.py" "$@"
    ;;
  access-hardening)
    python "$SCRIPTS/agent-os-access-hardening-audit.py" "$@"
    ;;
  honcho-ab)
    python "$SCRIPTS/honcho-ab-sandbox-eval.py" "$@"
    ;;
  help|*)
    cat <<'EOF'
agent-os-quick commands:
  doctor-all
  profile-audit
  skill-sync-check
  relay-smoke-test
  mcp-test
  voice-smoke
  agent-os-health
  behavioral-regression
  access-hardening
  honcho-ab
EOF
    ;;
esac
