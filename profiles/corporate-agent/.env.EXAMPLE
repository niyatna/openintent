# Environment variables required by this Hermes profile distribution.
# Copy to .env locally and fill values. Do not commit real .env.

# Local 9router connection key.
# required
9ROUTER_API_KEY=

# Context7 MCP authorization token.
# required
CONTEXT7_API_KEY=

# Hindsight memory API key for production memory (if using cloud/external embeddings).
# optional
HINDSIGHT_LLM_API_KEY=

# Discord gateway bot token for corporate-agent.
# optional
DISCORD_BOT_TOKEN=

# Trusted human Discord user allowlist.
# optional
DISCORD_ALLOWED_USERS=

# Bot-message acceptance policy; use 'mentions' for controlled bot-to-bot relay.
# optional
# default: mentions
DISCORD_ALLOW_BOTS=

# Repeat raw mention on split Discord chunks for deterministic relay.
# optional
# default: true
DISCORD_REPEAT_MENTIONS_ON_SPLIT=

# Groq Whisper STT key for Indonesian voice transcription.
# optional
GROQ_API_KEY=

# Obsidian vault path for corporate-agent-readable continuity notes.
# optional
OBSIDIAN_VAULT_PATH=

# Telegram gateway bot token.
# optional
TELEGRAM_BOT_TOKEN=

# Email integration address.
# optional
EMAIL_ADDRESS=

# Email integration app password.
# optional
EMAIL_PASSWORD=

# Linear MCP OAuth/auth state; configured interactively, not stored in distribution.
# optional
LINEAR_MCP_AUTH=

# Notion MCP OAuth/auth state; configured interactively and by sharing Notion pages/databases with the connection.
# optional
NOTION_MCP_AUTH=

# ntfy topic for corporate-agent push notifications; optional if config.yaml extra.topic is set. Use a private/random topic and do not publish it.
# optional
NTFY_TOPIC=

# Optional ntfy bearer/basic token for protected/self-hosted ntfy topics.
# optional
NTFY_TOKEN=

# Bitwarden Secrets Manager machine-account access token for corporate-agent; required only after secrets.bitwarden.enabled is true.
# optional
CORPORATE_BWS_ACCESS_TOKEN=
